# Copie este ficheiro para .env.local na RAIZ do projeto (junto a package.json).

# Senha do painel /recepcao (balcão)
RECEPTION_PASSWORD=coloque-uma-senha-segura

# --- Opção A: Supabase na nuvem ---
# Dashboard do projeto → Settings → API
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Opção B: Supabase local (Docker + CLI) ---
# Terminal: npx supabase start
# Depois: npx supabase status  (copie "service_role key" para baixo)
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_SERVICE_ROLE_KEY=
